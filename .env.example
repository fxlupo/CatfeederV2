COMPOSE_PROJECT_NAME=catfeeder

MQTT_DEVICE_ID=catfeeder
MQTT_DEVICE_USER=catfeeder
MQTT_DEVICE_PASS=catfeeder-device-change-me
MQTT_BACKEND_USER=backend
MQTT_BACKEND_PASS=catfeeder-backend-change-me

POSTGRES_DB=catfeeder
POSTGRES_USER=catfeeder
POSTGRES_PASSWORD=catfeeder-db-change-me

BACKEND_PORT=3000
FRONTEND_PORT=8080

# Push-Benachrichtigungen – optional, beide Provider können unabhängig aktiviert werden

# ntfy.sh (zero-infrastructure, kein Account nötig)
# Kanal-Namen selbst wählen – je einzigartiger, desto besser
# NTFY_URL=https://ntfy.sh/catfeeder-mein-eindeutiger-kanal

# Web Push / VAPID (Browser-Benachrichtigungen)
# Schlüssel einmalig generieren:
#   cd platform/backend && npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_CONTACT=mailto:deine@email.de

PUBLIC_HOST=catfeeder.mydomain.de
TRAEFIK_CERTRESOLVER=http
